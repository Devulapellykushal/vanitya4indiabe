# Vanitya Environment Variables
# Copy this file to .env and replace with actual values

# Server Configuration
NODE_ENV=development
PORT=3000
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Database Configuration  
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vanitya
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vanitya
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration (for job queue)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ML Service Configuration
ML_SERVICE_URL=http://ml-service:8000
ML_SERVICE_TIMEOUT=30000

# API Keys
SARVAM_API_KEY=__REPLACE_WITH_YOUR_KEY__
AI4BHARAT_API_KEY=__REPLACE_WITH_YOUR_KEY__

# Optional: Override config values
SARVAM_API_URL=https://api.sarvam.ai/v1
DEFAULT_SOURCE_LANG=hi
DEFAULT_TARGET_LANG=te

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

########################################
# Vanitya backend bootstrap additions
########################################

# Database (DB_PASSWORD deprecated; prefer DB_PASS)
# If both are present in your environment, the backend should be configured to read DB_PASS going forward.
DB_PASS=password

# Credits threshold for Sarvam API fallback
SARVAM_CREDITS_THRESHOLD=50

# Firebase / Google auth configuration
FIREBASE_API_KEY=__REPLACE_WITH_YOUR_KEY__
FIREBASE_PROJECT_ID=__REPLACE_WITH_YOUR_PROJECT_ID__
GOOGLE_WEB_CLIENT_ID=__REPLACE_WITH_YOUR_CLIENT_ID__

# Application settings
# These control content density and life mechanics in the app
QUESTIONS_PER_UNIT=10
HEARTS_PER_USER=5

# Storage backend toggle: local or s3
STORAGE_BACKEND=local
