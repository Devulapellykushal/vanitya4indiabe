{
  "name": "vanitya-backend",
  "version": "1.0.0",
  "description": "Backend API service for Vanitya - Language Learning platform for Indic Languages",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:drop && sequelize-cli db:create && sequelize-cli db:migrate && sequelize-cli db:seed:all"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "sequelize": "^6.32.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "axios": "^1.5.0",
    "joi": "^17.9.2",
    "yaml": "^2.3.2",
    "bull": "^4.11.3",
    "redis": "^4.6.8",
    "multer": "^1.4.5-lts.1",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.4",
    "supertest": "^6.3.3",
    "sequelize-cli": "^6.6.1",
    "@types/jest": "^29.5.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "language-learning",
    "indic-languages",
    "express",
    "sequelize",
    "postgresql"
  ],
  "author": "Vanitya Team",
  "license": "MIT"
}