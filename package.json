{
  "name": "vanitya-backend",
  "version": "1.0.0",
  "description": "Backend API service for Vanitya - Language Learning platform for Indic Languages",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "sequelize-cli db:migrate",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:drop && sequelize-cli db:create && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "docker:build": "docker build -f deployment/docker/Dockerfile -t vanitya/backend .",
    "docker:run": "docker-compose -f deployment/docker/docker-compose.yml up",
    "docker:dev": "docker-compose -f deployment/docker/docker-compose.yml -f deployment/docker/docker-compose.dev.yml up",
    "k8s:deploy": "kubectl apply -f deployment/k8s/",
    "lint": "eslint src/ --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "redis": "^5.9.0",
    "sequelize": "^6.37.7",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "language-learning",
    "indic-languages",
    "express",
    "sequelize",
    "postgresql"
  ],
  "author": "Vanitya Team",
  "license": "MIT"
}
