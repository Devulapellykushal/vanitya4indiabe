# Testing Environment Configuration
NODE_ENV=test
HOST=localhost
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://localhost:5432/vanitya_test
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vanitya_test
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSL=false
DB_POOL_MAX=2
DB_POOL_MIN=0

# Authentication
JWT_SECRET=test-jwt-secret-key
JWT_EXPIRATION=1h
BCRYPT_ROUNDS=4

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_KEY_PREFIX=vanitya:test:

# External APIs (use test/mock endpoints)
SARVAM_API_URL=http://localhost:9001/mock/sarvam
SARVAM_API_KEY=test-sarvam-key
SARVAM_TIMEOUT=5000

AI4BHARAT_API_URL=http://localhost:9001/mock/ai4bharat
AI4BHARAT_API_KEY=test-ai4bharat-key
AI4BHARAT_TIMEOUT=5000

AKSHARAMUKHA_URL=http://localhost:9001/mock/aksharamukha
AKSHARAMUKHA_API_KEY=test-aksharamukha-key
AKSHARAMUKHA_TIMEOUT=5000

ML_SERVICE_URL=http://localhost:9001/mock/ml
ML_SERVICE_TIMEOUT=5000

# Rate Limiting (disabled for testing)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Logging
LOG_LEVEL=error
LOG_FORMAT=tiny

# CORS
CORS_ORIGIN=*

# Health Check
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=1000

# Application Settings
SUPPORTED_LANGUAGES=hi,te,en
DEFAULT_SOURCE_LANGUAGE=hi
DEFAULT_TARGET_LANGUAGE=te

GAME_HEARTS_INITIAL=5
GAME_HEARTS_DEDUCT=1
GAME_RETRY_MAX=3

UPLOAD_MAX_FILE_SIZE=1048576
UPLOAD_ALLOWED_TYPES=audio/wav