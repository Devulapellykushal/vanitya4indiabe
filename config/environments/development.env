# Development Environment Configuration
NODE_ENV=development
HOST=localhost
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://localhost:5432/vanitya
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vanitya
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSL=false
DB_POOL_MAX=5
DB_POOL_MIN=0

# Authentication
JWT_SECRET=your-development-jwt-secret-key-here
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=vanitya:dev:

# External APIs
SARVAM_API_URL=https://api.sarvam.ai/v1
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_TIMEOUT=30000
SARVAM_CREDITS=900

AI4BHARAT_API_URL=https://api.ai4bharat.org
AI4BHARAT_API_KEY=your-ai4bharat-api-key
AI4BHARAT_TIMEOUT=30000

# OpenAI API (Fallback Provider)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1

AKSHARAMUKHA_URL=https://aksharamukha.appspot.com
AKSHARAMUKHA_API_KEY=your-aksharamukha-api-key
AKSHARAMUKHA_TIMEOUT=15000

ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=60000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_SKIP_SUCCESS=false
RATE_LIMIT_SKIP_FAILED=false

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# Health Check
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000

# Application Settings
SUPPORTED_LANGUAGES=hi,te,kn,ta,ml,en
DEFAULT_SOURCE_LANGUAGE=hi
DEFAULT_TARGET_LANGUAGE=te

GAME_HEARTS_INITIAL=5
GAME_HEARTS_DEDUCT=1
GAME_RETRY_MAX=3

UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=audio/wav,audio/mp3,audio/ogg