# Production Environment Configuration
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=true

# Database Configuration
DATABASE_URL=${DATABASE_URL}
DB_SSL=true
DB_POOL_MAX=20
DB_POOL_MIN=5

# Authentication
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=12

# Redis Configuration
REDIS_URL=${REDIS_URL}
REDIS_KEY_PREFIX=vanitya:prod:

# External APIs
SARVAM_API_URL=https://api.sarvam.ai/v1
SARVAM_API_KEY=${SARVAM_API_KEY}
SARVAM_TIMEOUT=30000
SARVAM_CREDITS=900

AI4BHARAT_API_URL=https://api.ai4bharat.org
AI4BHARAT_API_KEY=${AI4BHARAT_API_KEY}
AI4BHARAT_TIMEOUT=30000

AKSHARAMUKHA_URL=https://aksharamukha.appspot.com
AKSHARAMUKHA_API_KEY=${AKSHARAMUKHA_API_KEY}
AKSHARAMUKHA_TIMEOUT=15000

ML_SERVICE_URL=${ML_SERVICE_URL}
ML_SERVICE_TIMEOUT=60000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESS=true
RATE_LIMIT_SKIP_FAILED=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_FILE_PATH=/var/log/vanitya/app.log
LOG_MAX_SIZE=100m
LOG_MAX_FILES=5

# CORS
CORS_ORIGIN=${CORS_ORIGIN}

# Health Check
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000

# Application Settings
SUPPORTED_LANGUAGES=hi,te,kn,ta,ml,en
DEFAULT_SOURCE_LANGUAGE=hi
DEFAULT_TARGET_LANGUAGE=te

GAME_HEARTS_INITIAL=5
GAME_HEARTS_DEDUCT=1
GAME_RETRY_MAX=3

UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=audio/wav,audio/mp3,audio/ogg