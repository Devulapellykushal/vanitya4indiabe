# Docker ignore patterns for Vanitya Backend

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Environment files
.env
.env.local
.env.*.local
config/environments/*.env

# Logs
logs/
*.log
/var/log/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
.nyc_output

# ESLint cache
.eslintcache

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git/
.gitignore

# Documentation
docs/
README.md
CHANGELOG.md

# Test files
src/test/
test/
tests/
__tests__/
*.test.js
*.spec.js

# Development files
.watchmanconfig
jest.config.js
.sequelizerc

# Build artifacts
build/
dist/
temp/

# Database files
*.sqlite
*.db

# Temporary files
tmp/
temp/